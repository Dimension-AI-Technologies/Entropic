<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Entropic.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Entropic.GUI.Views.CommitView"
             x:DataType="vm:CommitViewModel">

    <UserControl.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#35373b"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#e6292b2f"/>
            <Setter Property="Foreground" Value="#8e9297"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="BorderBrush" Value="#35373b"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="DataGridRow /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#42464d"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Background="#d936393f">
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#e6292b2f"
                BorderBrush="#35373b" BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="COMMITS" Foreground="#8e9297" FontSize="11"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding RepoName}" Foreground="#dcddde" FontWeight="SemiBold"
                           FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Foreground="#72767d" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"
                           IsVisible="{Binding SelectedRepoPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Run Text="{Binding Commits.Count}"/>
                    <Run Text=" commits"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Error display -->
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#faa61a"
                   HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="12"
                   Margin="0,8" DockPanel.Dock="Top"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Empty state -->
        <TextBlock Text="Select a repository in Git View, then click View Commits"
                   Foreground="#72767d" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14"
                   IsVisible="{Binding SelectedRepoPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />

        <DataGrid ItemsSource="{Binding Commits}" AutoGenerateColumns="False" IsReadOnly="True"
                  Foreground="#dcddde"
                  IsVisible="{Binding SelectedRepoPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="HASH" Binding="{Binding ShortHash}" Width="80" />
                <DataGridTextColumn Header="DATE" Binding="{Binding Date}" Width="180" />
                <DataGridTextColumn Header="AUTHOR" Binding="{Binding AuthorName}" Width="150" />
                <DataGridTextColumn Header="MESSAGE" Binding="{Binding Message}" Width="*" />
                <DataGridTextColumn Header="STATS" Binding="{Binding StatsText}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
