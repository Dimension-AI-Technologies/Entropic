<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Entropic.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Entropic.GUI.Views.ProjectView"
             x:DataType="vm:ProjectsViewModel">

    <UserControl.Styles>
        <!-- Filter pill buttons -->
        <Style Selector="Button.filterPill">
            <Setter Property="Background" Value="#2f3136"/>
            <Setter Property="Foreground" Value="#8e9297"/>
            <Setter Property="BorderBrush" Value="#35373b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.filterPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3d42"/>
        </Style>
        <!-- Session tab buttons -->
        <Style Selector="Button.sessionTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8e9297"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.sessionTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3a3d42"/>
            <Setter Property="BorderBrush" Value="#5865f2"/>
        </Style>
        <Style Selector="Button.sessionTab.active">
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="BorderBrush" Value="#5865f2"/>
        </Style>
        <Style Selector="Button.sessionTab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#42464d"/>
            <Setter Property="BorderBrush" Value="#5865f2"/>
        </Style>
        <!-- Control bar filter toggles -->
        <Style Selector="ToggleButton.statusFilter">
            <Setter Property="Background" Value="#2f3136"/>
            <Setter Property="Foreground" Value="#8e9297"/>
            <Setter Property="BorderBrush" Value="#35373b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style Selector="ToggleButton.statusFilter:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#5865f2"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <!-- Delete/action buttons -->
        <Style Selector="Button.dangerBtn">
            <Setter Property="Background" Value="#4f292b"/>
            <Setter Property="Foreground" Value="#ed4245"/>
            <Setter Property="BorderBrush" Value="#5c3133"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.dangerBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5c3133"/>
        </Style>
        <Style Selector="Button.mergeBtn">
            <Setter Property="Background" Value="#2f3a4f"/>
            <Setter Property="Foreground" Value="#7aa2f7"/>
            <Setter Property="BorderBrush" Value="#3a4a5c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- Sidebar project list -->
        <Style Selector="ListBox.projectList">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox.projectList ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ListBox.projectList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#42464d"/>
        </Style>
        <Style Selector="ListBox.projectList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#36393f"/>
        </Style>
        <!-- Todo list -->
        <Style Selector="ListBox.todoList">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBox.todoList ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <!-- Todo card hover + shadow -->
        <Style Selector="ListBox.todoList ListBoxItem Border">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
            <Setter Property="BoxShadow" Value="0 1 3 0 rgba(0,0,0,0.15)"/>
        </Style>
        <Style Selector="ListBox.todoList ListBoxItem:pointerover Border">
            <Setter Property="Background" Value="#35373b"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 rgba(0,0,0,0.3)"/>
        </Style>
        <!-- Project list hover transition -->
        <Style Selector="ListBox.projectList ListBoxItem /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="260,Auto,*,Auto,280">
        <!-- Left pane: Project list -->
        <DockPanel Grid.Column="0" Background="#e02f3136">
            <!-- Filter bar -->
            <Border DockPanel.Dock="Top" Background="#e6292b2f"
                    BorderBrush="#35373b" BorderThickness="0,0,0,1"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <Button Classes="filterPill" Content="All"
                            Command="{Binding SetFilterCommand}" CommandParameter="all" />
                    <Button Classes="filterPill" Content="Sessions"
                            Command="{Binding SetFilterCommand}" CommandParameter="hasSessions" />
                    <Button Classes="filterPill" Content="Todos"
                            Command="{Binding SetFilterCommand}" CommandParameter="hasTodos" />
                    <Button Classes="filterPill" Content="Active"
                            Command="{Binding SetFilterCommand}" CommandParameter="activeOnly" />
                </StackPanel>
            </Border>
            <ListBox Classes="projectList" ItemsSource="{Binding Projects}"
                     SelectedItem="{Binding SelectedProject}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:ProjectItemViewModel">
                        <DockPanel>
                            <!-- Provider badge -->
                            <Border DockPanel.Dock="Left" CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                    Background="#292b2f">
                                <TextBlock Text="{Binding Provider}" FontSize="10" FontWeight="Bold"
                                           Foreground="#7aa2f7"/>
                            </Border>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding TodoCount, StringFormat='({0})'}"
                                       Foreground="#72767d" FontSize="11"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Foreground="#dcddde"
                                           FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SessionCount, StringFormat='{}{0} sessions'}"
                                           Foreground="#72767d" FontSize="11"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <!-- REQ-GUI-004: Context menu on projects -->
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Path" Command="{Binding CopyPathCommand}" />
                        <MenuItem Header="Open in Explorer" Command="{Binding OpenInExplorerCommand}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="1" Background="#35373b" />

        <!-- Middle pane: Session strip (horizontal scroll) + todo list below -->
        <DockPanel Grid.Column="2" Background="#d936393f">
            <!-- Session tab strip — fixed height, horizontal scroll -->
            <Border DockPanel.Dock="Top" Background="#e02f3136"
                    BorderBrush="#35373b" BorderThickness="0,0,0,1"
                    Height="38">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SelectedProject.Sessions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:SessionItemViewModel">
                                <Button Classes="sessionTab"
                                        Classes.active="{Binding IsSelected}"
                                        Content="{Binding ShortLabel}"
                                        Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).SelectSessionCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Session control bar: filters + actions -->
            <Border DockPanel.Dock="Top" Background="#e6292b2f"
                    BorderBrush="#35373b" BorderThickness="0,0,0,1"
                    Padding="8,5"
                    IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}">
                <DockPanel>
                    <!-- Right: action buttons -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                        <Button Classes="filterPill" Content="View Chat"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ViewChatForSessionCommand}"
                                CommandParameter="{Binding SelectedSession}" />
                        <Button Classes="mergeBtn"
                                Content="{Binding SelectedProject.Sessions.Count, StringFormat='Merge ({0})'}"
                                Command="{Binding StartMergeCommand}"
                                IsVisible="{Binding SelectedProject.Sessions.Count, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button Classes="dangerBtn"
                                Content="{Binding EmptySessionCount, StringFormat='Delete Empty ({0})'}"
                                Command="{Binding DeleteEmptySessionsCommand}" />
                        <!-- Delete session with confirmation -->
                        <Button Classes="dangerBtn" Content="Delete Session"
                                IsVisible="{Binding !ShowDeleteConfirm}"
                                Command="{Binding SetShowDeleteConfirmCommand}" CommandParameter="true" />
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding ShowDeleteConfirm}">
                            <TextBlock Text="Delete?" Foreground="#ed4245" FontSize="11" VerticalAlignment="Center" />
                            <Button Classes="dangerBtn" Content="Yes" Command="{Binding DeleteSelectedSessionCommand}" />
                            <Button Classes="filterPill" Content="No"
                                    Command="{Binding SetShowDeleteConfirmCommand}" CommandParameter="false" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Left: status filter toggles -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Filter:" Foreground="#8e9297" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ToggleButton Classes="statusFilter" Content="Done" IsChecked="{Binding ShowCompleted}" />
                        <ToggleButton Classes="statusFilter" Content="Doing" IsChecked="{Binding ShowInProgress}" />
                        <ToggleButton Classes="statusFilter" Content="Pending" IsChecked="{Binding ShowPending}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Todo list for selected session (filtered) -->
            <ListBox Classes="todoList"
                     ItemsSource="{Binding FilteredTodos}"
                     SelectedItem="{Binding SelectedTodoItem}"
                     Margin="8"
                     IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:TodoItemViewModel">
                        <Border Background="#2f3136" CornerRadius="4"
                                Padding="10,8" Margin="0,0,0,4"
                                BorderBrush="#35373b" BorderThickness="1">
                            <Grid ColumnDefinitions="24,*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                           Foreground="{Binding StatusColor}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayText}"
                                           Foreground="#dcddde" FontSize="13"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" Margin="8,0"/>
                                <Button Grid.Column="2" Content="Toggle"
                                        Command="{Binding ToggleStatusCommand}"
                                        FontSize="10" Padding="8,3"
                                        Background="#292b2f" Foreground="#b9bbbe"
                                        BorderBrush="#35373b" BorderThickness="1"
                                        CornerRadius="3" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Toggle Status"
                                  Command="{Binding SelectedTodoItem.ToggleStatusCommand}"
                                  IsEnabled="{Binding SelectedTodoItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <MenuItem Header="Edit"
                                  Command="{Binding SelectedTodoItem.StartEditCommand}"
                                  IsEnabled="{Binding SelectedTodoItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>

            <!-- Empty state when no session selected -->
            <TextBlock Text="Select a session above" Foreground="#72767d"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                       IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNull}}" />
        </DockPanel>

        <GridSplitter Grid.Column="3" Width="1" Background="#35373b" />

        <!-- Merge dialog overlay (spans middle pane) -->
        <Border Grid.Column="2" IsVisible="{Binding IsMergeDialogOpen}"
                Background="rgba(0,0,0,0.5)" ZIndex="10">
            <Border Background="#1f2227" CornerRadius="8" Padding="20,16"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="360" BorderBrush="#3a3d42" BorderThickness="1"
                    BoxShadow="0 12 30 0 rgba(0,0,0,0.4)">
                <StackPanel Spacing="12">
                    <TextBlock Text="Merge Sessions" Foreground="#ffffff" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding MergePreviewText}" Foreground="#b9bbbe" FontSize="13" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="filterPill" Command="{Binding CancelMergeCommand}" />
                        <Button Content="Merge" Classes="mergeBtn" Command="{Binding ConfirmMergeCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Right pane: Summary for selected project -->
        <DockPanel Grid.Column="4" Background="#e02f3136">
            <Border DockPanel.Dock="Top" Background="#e6292b2f"
                    BorderBrush="#35373b" BorderThickness="0,0,0,1"
                    Padding="12,8">
                <TextBlock Text="Summary" Foreground="#dcddde" FontSize="13" FontWeight="SemiBold"/>
            </Border>
            <StackPanel Margin="12,10"
                        IsVisible="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Foreground="#dcddde" Margin="0,4" FontSize="13">
                    <Run Text="Path" Foreground="#8e9297"/>
                </TextBlock>
                <TextBlock Text="{Binding SelectedProject.Path}" Foreground="#b9bbbe"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Foreground="#dcddde" Margin="0,4" FontSize="13">
                    <Run Text="Provider" Foreground="#8e9297"/>
                </TextBlock>
                <TextBlock Text="{Binding SelectedProject.Provider}" Foreground="#b9bbbe"
                           FontSize="12" Margin="0,0,0,10"/>

                <Border Background="#292b2f" CornerRadius="4" Padding="10,8" Margin="0,4">
                    <StackPanel>
                        <TextBlock Foreground="#dcddde" FontSize="13">
                            <Run Text="{Binding SelectedProject.SessionCount}"/>
                            <Run Text=" sessions" Foreground="#8e9297"/>
                        </TextBlock>
                        <TextBlock Foreground="#dcddde" FontSize="13" Margin="0,4,0,0">
                            <Run Text="{Binding SelectedProject.TodoCount}"/>
                            <Run Text=" TODOs" Foreground="#8e9297"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
            <TextBlock Text="Select a project" Foreground="#72767d"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"
                       IsVisible="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNull}}" />
        </DockPanel>
    </Grid>
</UserControl>
