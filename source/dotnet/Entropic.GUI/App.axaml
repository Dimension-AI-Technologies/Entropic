<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Entropic.GUI.App"
             xmlns:local="using:Entropic.GUI"
             RequestedThemeVariant="Dark">
             <!-- @must_test(REQ-GUI-006) Dark theme -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>