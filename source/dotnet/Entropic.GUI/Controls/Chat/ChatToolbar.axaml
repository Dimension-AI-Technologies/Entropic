<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Entropic.GUI.ViewModels"
             x:Class="Entropic.GUI.Controls.Chat.ChatToolbar"
             x:DataType="vm:ChatViewModel">

  <UserControl.Styles>
    <Style Selector="Button.tb">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ChatBtnBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="5,1"/>
      <Setter Property="MinWidth" Value="24"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Height" Value="20"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="{DynamicResource ChatBtnFg}"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.tb:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChatBtnHover}"/>
    </Style>
    <Style Selector="CheckBox.flt">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource ChatBtnFg}"/>
      <Setter Property="Margin" Value="4,0"/>
      <Setter Property="Padding" Value="4,0"/>
      <Setter Property="MinHeight" Value="0"/>
    </Style>
    <!-- Reduce internal padding on TextBox controls in this toolbar -->
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="MinHeight" Value="0"/>
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource ChatToolbarBg}" BorderBrush="{DynamicResource ChatToolbarBorder}" BorderThickness="0,0,0,2" Padding="8,2">
    <WrapPanel Orientation="Horizontal">
      <!-- Title group Ã¢â‚¬â€ inline -->
      <TextBlock Text="{Binding RepoTitle}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource ChatTextFg}"
                 VerticalAlignment="Center" Margin="0,0,8,0"/>
      <TextBlock Text="{Binding GeneratedTime}" FontSize="9" Foreground="{DynamicResource ChatRoleFg}"
                 VerticalAlignment="Center" Margin="0,0,12,0"/>

      <!-- Search -->
      <TextBox Text="{Binding SearchText, Mode=TwoWay}" Watermark="Search..."
               Width="130" FontSize="11" Margin="0,0,8,0" Padding="4,0"
               VerticalContentAlignment="Center" Height="20"/>

      <!-- Filter checkboxes -->
      <CheckBox Classes="flt" Content="CLI" IsChecked="{Binding ShowCli}" Margin="4,0"/>
      <CheckBox Classes="flt" Content="Plans" IsChecked="{Binding ShowPlans}" Margin="4,0"/>
      <CheckBox Classes="flt" Content="Tasks" IsChecked="{Binding ShowTasks}" Margin="4,0"/>
      <CheckBox Classes="flt" Content="Subagents" IsChecked="{Binding ShowSubagents}" Margin="4,0"/>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Message limit -->
      <TextBlock Text="Last" FontSize="10" Foreground="{DynamicResource ChatMutedFg}"
                 VerticalAlignment="Center" Margin="0,0,3,0"/>
      <TextBox Name="MessageLimitBox" Text="{Binding MessageLimit}"
               Width="52" FontSize="10" Padding="3,0" Height="20"
               VerticalContentAlignment="Center" TextAlignment="Center"
               ToolTip.Tip="Number of messages to load (from most recent)"
               KeyDown="OnMessageLimitKeyDown" LostFocus="OnMessageLimitLostFocus"/>
      <TextBlock Text="{Binding MessageLimitLabel}" FontSize="9" Foreground="{DynamicResource ChatMutedFg}"
                 VerticalAlignment="Center" Margin="4,0"/>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Collapse toggle -->
      <Button Classes="tb" Content="&#x2630;" Click="OnCollapseClick"
              ToolTip.Tip="Collapse/expand assistant responses" Margin="1,0"/>

      <!-- Theme toggle -->
      <Button Classes="tb" Content="&#x2600;" Click="OnThemeClick"
              ToolTip.Tip="Toggle light/dark theme" Margin="1,0"/>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Prompt navigation -->
      <Button Classes="tb" Content="&#x25B2;" Click="OnNavUpClick"
              ToolTip.Tip="Previous user prompt" Margin="1,0"/>
      <TextBlock Text="{Binding NavPositionText}" FontSize="11" Foreground="{DynamicResource ChatMutedFg}"
                 VerticalAlignment="Center" Margin="4,0" MinWidth="45"
                 TextAlignment="Center"/>
      <Button Classes="tb" Content="&#x25BC;" Click="OnNavDownClick"
              ToolTip.Tip="Next user prompt" Margin="1,0"/>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Copy buttons -->
      <Button Classes="tb" Click="OnCopyMarkdown" ToolTip.Tip="Copy as Markdown" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x29C9;" FontSize="13"/><TextBlock Text="md" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>
      <Button Classes="tb" Click="OnCopyText" ToolTip.Tip="Copy as plain text" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x29C9;" FontSize="13"/><TextBlock Text="txt" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>
      <Button Classes="tb" Click="OnCopyHtml" ToolTip.Tip="Copy as HTML" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x29C9;" FontSize="13"/><TextBlock Text="htm" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Save buttons -->
      <Button Classes="tb" Click="OnSaveMarkdown" ToolTip.Tip="Save as Markdown" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x2913;" FontSize="13"/><TextBlock Text="md" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>
      <Button Classes="tb" Click="OnSaveText" ToolTip.Tip="Save as plain text" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x2913;" FontSize="13"/><TextBlock Text="txt" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>
      <Button Classes="tb" Click="OnSaveHtml" ToolTip.Tip="Save as HTML" Margin="1,0" Padding="4,1">
        <StackPanel Orientation="Horizontal" Spacing="2"><TextBlock Text="&#x2913;" FontSize="13"/><TextBlock Text="htm" FontSize="9" VerticalAlignment="Center"/></StackPanel>
      </Button>

      <!-- Separator -->
      <Border Width="1" Height="18" Background="{DynamicResource ChatBtnBorder}" Margin="6,0"/>

      <!-- Screenshot -->
      <Button Classes="tb" Click="OnScreenshotClick" ToolTip.Tip="Screenshot (F12)" Margin="1,0" Padding="4,1">
        <TextBlock Text="&#x1F4F7;" FontSize="12"/>
      </Button>

      <!-- Follow -->
      <CheckBox Classes="flt" Content="Follow" IsChecked="{Binding IsFollowMode}" Margin="4,0"/>
    </WrapPanel>
  </Border>
</UserControl>
