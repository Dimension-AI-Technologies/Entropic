# PolyScript Framework - Cross-language build artifacts and general patterns
# Note: Each language framework has its own detailed .gitignore for language-specific patterns

# Cross-platform OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# Common IDE files (cross-language)
.vscode/
.idea/
.vs/
*.swp
*.swo
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Common build directories (that might appear at framework root level)
build/
dist/
target/
bin/
obj/

# Common log and temporary patterns
*.log
*.tmp
*.temp
*.bak

# Test executables (common naming patterns across languages)
test_*
*_test
TestCompiler*
test-compiler*
testcompiler*

# Environment and config files
.env
.venv
.env.local
.env.*.local

# Package manager lock files (when they appear at root)
package-lock.json
yarn.lock
Cargo.lock
go.sum
composer.lock
Gemfile.lock
mix.lock
Pipfile.lock
poetry.lock

# Coverage reports (cross-language)
coverage/
.coverage
*.lcov
*.cov
htmlcov/

# Documentation build artifacts
docs/build/
docs/site/
_site/